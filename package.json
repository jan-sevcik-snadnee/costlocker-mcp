{
  "name": "costlocker-mcp",
  "version": "1.0.0",
  "description": "Costlocker integration for Claude Desktop via Model Context Protocol (MCP)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "type-check": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "costlocker",
    "claude",
    "claude-desktop",
    "time-tracking",
    "project-management"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.3",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "package.json",
    "tsconfig.json"
  ]
}
